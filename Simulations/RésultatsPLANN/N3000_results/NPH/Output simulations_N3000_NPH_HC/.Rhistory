############## paramètres estimés par CV ###########
m2value <- paste0(m2, failedCVindic)
paramsCV <- as.data.frame(c(inter = inter,size = size,decay = decay, maxit = maxit,
MaxNWts = MaxNWts, m1 = m1, m2 = m2value))
write.table(paramsCV,  paste0(path0, "PARAM/",i,"_param.csv"))
############# temps écoulé total & par CV de chaque modèle et taille de la base #########################
timeComputation <- as.data.frame(c(time = time, plann = TimeCVplann, flex1 = TimeCVflex1,
flex2 = TimeCVflex2, N = dim(data)[1]))
write.table(timeComputation,  paste0(path0, "TIME/",i,"_time.csv"))
##############Log(LIKELIHOOD)#######################
# plann.loglik <- plann.model$loglik  # @YOHANN VERIFIER log.lik dans PLANN// IL FAUT REMMTTRE LA LOGLIK DANS predictRS
flex1.loglik <- unname(flex.model1$loglik[1])
if(class(flex.model2) == "survivalNET"){
flex2.loglik <- unname(flex.model2$loglik[1])
}else{ flex2.loglik <- paste0(" Error : flex.model2 doesn't exist.")}
WG.loglik <- unname(WG.model$loglik[1])
# logliks <- as.data.frame(c(plann = plann.loglik, flex1 = flex1.loglik, flex2 = flex2.loglik, WG = WG.loglik))
logliks <- as.data.frame(c(flex1 = flex1.loglik, flex2 = flex2.loglik, WG = WG.loglik))
write.table(logliks,  paste0(path0, "LOGLIK/",i,"_loglik.csv"))
